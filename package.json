{
  "name": "topospace",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/topospace.cjs",
  "module": "./dist/topospace.mjs",
  "types": "./src/public-api.d.ts",
  "exports": {
    ".": {
      "types": "./src/public-api.d.ts",
      "import": "./dist/topospace.mjs",
      "require": "./dist/topospace.cjs"
    },
    "./styles": "./dist/topospace.css"
  },
  "files": [
    "dist/topospace.mjs",
    "dist/topospace.cjs",
    "dist/topospace.css",
    "src/public-api.d.ts",
    "src/types"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "author": "cheonghakim",
  "repository": {
    "type": "git",
    "url": "https://github.com/cheonghakim/topo-space"
  },
  "homepage": "https://cheonghakim.github.io/topo-space",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "docs:api": "typedoc"
  },
  "dependencies": {
    "@types/three": "^0.184.1",
    "exceljs": "^4.4.0",
    "pinia": "^3.0.0",
    "three-mesh-bvh": "^0.9.10"
  },
  "peerDependencies": {
    "pinia": "^3.0.0",
    "three": "^0.184.0",
    "vue": "^3.5.0"
  },
  "overrides": {
    "uuid": ">=11.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "three": "^0.184.0",
    "typedoc": "^0.28.19",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.8"
  }
}
